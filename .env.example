# =============================================================
# SUPABASE — Primary Database (PostgreSQL)
# Get these from: Supabase Dashboard → Project Settings → Database
# =============================================================

# Pooled connection string (Session mode, port 6543) — used at runtime
DATABASE_URL="your_pooled_connection_string_here"

# Direct (non-pooled) connection string (port 5432) — used for migrations only
DIRECT_URL="your_direct_connection_string_here"

# =============================================================
# SUPABASE — JS Client (for realtime / storage features)
# Get these from: Supabase Dashboard → Project Settings → API
# =============================================================

# Public Supabase URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Public Supabase Anon Key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"

# Server-only: Supabase Service Role Key (NEVER commit or expose)
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"
